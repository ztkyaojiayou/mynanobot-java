<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  huazai-trip-plan 统一 Checkstyle 规则集（C-002 质量门禁）。
  集中管理，子模块经根 POM 复用，不允许各模块各写一套（change.md 设计约束）。

  机械化守护 .harness/rules/工程结构.md §5 文件组织约束 与 编码规范.md §8 质量指标：
    - 文件 ≤ 500 行（FileLength）
    - 方法 ≤ 50 行（MethodLength）
    - 圈复杂度 ≤ 10（CyclomaticComplexity）
    - 一个文件一个 public 类（OneTopLevelClass）
    - public 类/方法必须有 Javadoc（JavadocType / MissingJavadocMethod）
    - 禁止未用 import（UnusedImports / RedundantImport）
    - 禁止 System.out / System.err 滥用（编码规范 §7）
  违规即构建失败（severity=error，绑定 validate 阶段）。
-->
<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java"/>

    <!-- 文件长度 ≤ 500 行（工程结构 §5） -->
    <module name="FileLength">
        <property name="max" value="500"/>
    </module>

    <!-- 禁止 System.out / System.err（编码规范 §7：用日志框架，不裸打印） -->
    <module name="RegexpSingleline">
        <property name="format" value="System\.(out|err)\."/>
        <property name="message" value="禁止使用 System.out/System.err，请使用日志框架（编码规范 §7）。"/>
    </module>

    <!-- 基础硬编码密钥告警（编码规范 §7 安全红线，密钥走环境变量/配置中心） -->
    <module name="RegexpSingleline">
        <property name="format" value="(?i)(password|passwd|secret|api[_-]?key|access[_-]?token)\s*=\s*&quot;[^&quot;]+&quot;"/>
        <property name="message" value="疑似硬编码密钥；API Key/Token/密码必须走环境变量或配置中心（编码规范 §7）。"/>
    </module>

    <module name="TreeWalker">
        <!-- 方法长度 ≤ 50 行 -->
        <module name="MethodLength">
            <property name="tokens" value="METHOD_DEF, CTOR_DEF, COMPACT_CTOR_DEF"/>
            <property name="max" value="50"/>
            <property name="countEmpty" value="false"/>
        </module>

        <!-- 圈复杂度 ≤ 10 -->
        <module name="CyclomaticComplexity">
            <property name="max" value="10"/>
        </module>

        <!-- 一个文件一个 public 顶层类 -->
        <module name="OneTopLevelClass"/>

        <!-- public 类型必须有 Javadoc（编码规范 §2） -->
        <module name="JavadocType">
            <property name="scope" value="public"/>
        </module>

        <!-- public 方法/构造必须有 Javadoc；@Override 等默认豁免 -->
        <module name="MissingJavadocMethod">
            <property name="scope" value="public"/>
            <property name="allowMissingPropertyJavadoc" value="false"/>
            <property name="minLineCount" value="-1"/>
        </module>

        <!-- 未用 / 冗余 import -->
        <module name="UnusedImports"/>
        <module name="RedundantImport"/>
    </module>
</module>

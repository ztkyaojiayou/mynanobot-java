# API Key 密钥配置（不提交到 Git）
# 复制此文件为 secret.yaml 并填入真实 Key
#    cp secret.yaml.example secret.yaml

providers:
  deepseek:
    apiKey: "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
  openai:
    apiKey: ""  # 不用 OpenAI 就留空

tools:
  web:
    search:
      baidu: ""     # 百度千帆 AI 搜索 Key
      bing: ""      # Azure Bing Search Key
      brave: ""     # Brave Search Key

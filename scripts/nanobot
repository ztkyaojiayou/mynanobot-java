#!/bin/bash
# nanobot — 在任何目录下运行（自动取当前目录为工作区）
# 安装: 把此脚本所在目录加到 PATH 即可全局使用
#   export PATH="/d/IdeaProjects/个人项目/ai-vibe-coding/nanobot-java:$PATH"
SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
JAVA_HOME="${JAVA_HOME:-D:/devSoftWare/jdk17/jdk-17.0.19+10}"
export JAVA_HOME
export PATH="$JAVA_HOME/bin:$PATH"

# 自动编译（如需要）
if [[ ! -f "$SCRIPT_DIR/target/classes/com/nanobot/v3/NanobotCliApplication.class" ]]; then
    echo "(首次运行，正在编译...)"
    cd "$SCRIPT_DIR" && mvn compile -q -DskipTests
fi

cd "$SCRIPT_DIR"
java -cp "target/classes:$(mvn -q dependency:build-classpath -DincludeScope=compile -Dmdep.outputFile=/dev/stdout 2>/dev/null)" \
    com.nanobot.v3.NanobotCliApplication "$@"

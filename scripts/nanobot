#!/bin/bash
SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
JAVA_HOME="${JAVA_HOME:-D:/devSoftWare/jdk17/jdk-17.0.19+10}"
export JAVA_HOME
export PATH="$JAVA_HOME/bin:$PATH"

cd "$SCRIPT_DIR"
[[ ! -f target/nanobot-cli.jar ]] && { echo "building..."; mvn package -DskipTests -q; }

java -Dloader.main=com.nanobot.v3.NanobotCliApplication -jar target/nanobot-cli.jar "$@"

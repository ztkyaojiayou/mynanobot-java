#!/bin/bash
SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
JAVA_HOME="${JAVA_HOME:-D:/devSoftWare/jdk17/jdk-17.0.19+10}"
export JAVA_HOME
export PATH="$JAVA_HOME/bin:$PATH"

JAR="$SCRIPT_DIR/target/nanobot-cli.jar"

# 源码有更新？自动重新打包
if [[ ! -f "$JAR" ]] || [[ -n "$(find "$SCRIPT_DIR/src/main/java" -name '*.java' -newer "$JAR" 2>/dev/null | head -1)" ]]; then
    echo "(source changed, rebuilding...)"
    (cd "$SCRIPT_DIR" && mvn package -DskipTests -q)
fi

cd "$SCRIPT_DIR" && java -Dloader.main=com.nanobot.v3.NanobotCliApplication -jar "$JAR" "$@"

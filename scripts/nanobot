#!/bin/bash
# nanobot CLI — 在任何目录下运行，自动取当前目录为工作区
# 安装: export PATH="/d/IdeaProjects/个人项目/ai-vibe-coding/nanobot-java/scripts:$PATH"
SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
JAVA_HOME="${JAVA_HOME:-D:/devSoftWare/jdk17/jdk-17.0.19+10}"
export JAVA_HOME
export PATH="$JAVA_HOME/bin:$PATH"

# 首次使用需要打包 JAR
if [[ ! -f "$SCRIPT_DIR/target/nanobot-cli.jar" ]]; then
    echo "(首次运行，正在打包...)"
    (cd "$SCRIPT_DIR" && mvn package -DskipTests -q)
fi

java -jar "$SCRIPT_DIR/target/nanobot-cli.jar" "$@"
